<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">

  <Id>c6890c26-5bbb-40e2-916e-3f443f340163</Id>
  <Version>2.0.0.0</Version>
  <ProviderName>Magnus</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Claude Assistant"/>
  <Description DefaultValue="AI assistant for Outlook email"/>
  <IconUrl DefaultValue="https://skaflis.github.io/outlook-claude/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://skaflis.github.io/outlook-claude/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/Skaflis/outlook-claude"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://unrivaled-fudge-32c789.netlify.app/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="residTaskpaneUrl"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="grpRead">
                <Label resid="residGroupLabel"/>
                <Control xsi:type="Button" id="btnRead">
                  <Label resid="residButtonLabel"/>
                  <Supertip>
                    <Title resid="residButtonLabel"/>
                    <Description resid="residButtonTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="residIcon16"/>
                    <bt:Image size="32" resid="residIcon32"/>
                    <bt:Image size="80" resid="residIcon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="residTaskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="grpCompose">
                <Label resid="residGroupLabel"/>
                <Control xsi:type="Button" id="btnCompose">
                  <Label resid="residButtonLabel"/>
                  <Supertip>
                    <Title resid="residButtonLabel"/>
                    <Description resid="residButtonTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="residIcon16"/>
                    <bt:Image size="32" resid="residIcon32"/>
                    <bt:Image size="80" resid="residIcon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="residTaskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="residIcon16" DefaultValue="https://skaflis.github.io/outlook-claude/icon-16.png"/>
        <bt:Image id="residIcon32" DefaultValue="https://skaflis.github.io/outlook-claude/icon-32.png"/>
        <bt:Image id="residIcon80" DefaultValue="https://skaflis.github.io/outlook-claude/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="residTaskpaneUrl" DefaultValue="https://unrivaled-fudge-32c789.netlify.app/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="residGroupLabel" DefaultValue="Claude"/>
        <bt:String id="residButtonLabel" DefaultValue="Claude Assistant"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="residButtonTooltip" DefaultValue="Open Claude AI Assistant"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
