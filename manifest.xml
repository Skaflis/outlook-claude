<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="MailApp">

  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Magnus Skaflestad</ProviderName>
  <DefaultLocale>nb-NO</DefaultLocale>
  <DisplayName DefaultValue="Claude Assistant"/>
  <Description DefaultValue="AI-hjelp direkte i Outlook via Claude API"/>
  <IconUrl DefaultValue="https://cdn.jsdelivr.net/gh/Skaflis/outlook-claude@main/icon.png"/>
  <HighResolutionIconUrl DefaultValue="https://cdn.jsdelivr.net/gh/Skaflis/outlook-claude@main/icon.png"/>
  <SupportUrl DefaultValue="https://anthropic.com"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://skaflis.github.io/outlook-claude/taskpane.html"/>
        <RequestedHeight>500</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://skaflis.github.io/outlook-claude/taskpane.html"/>
        <RequestedHeight>500</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

</OfficeApp>
